# Required for CTAs (Ghana format examples)
NEXT_PUBLIC_PHONE=+233241234567
NEXT_PUBLIC_WHATSAPP=233241234567

# Optional — full street address for LocalBusiness schema & footer
NEXT_PUBLIC_BUSINESS_ADDRESS=

# Optional — Google Maps embed URL (iframe src)
NEXT_PUBLIC_MAP_EMBED_URL=

# Site URL for canonical, sitemap, OG (set in production)
NEXT_PUBLIC_SITE_URL=https://sensationalhairgh.example.com

# Optional analytics (loads only if set)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Optional — inquiry email via Resend (server-only)
# RESEND_API_KEY=
# INQUIRY_NOTIFY_EMAIL=
# Order notifications (falls back to INQUIRY_NOTIFY_EMAIL if unset)
# ORDER_NOTIFY_EMAIL=
